---
import type { SocialLinks } from '~/types'
import IconGithub from '~/icons/github.svg'
import IconMastodon from '~/icons/mastodon.svg'
import IconTwitter from '~/icons/twitter.svg'
import IconLinkedin from '~/icons/linkedin.svg'
import IconBluesky from '~/icons/bluesky.svg'
import IconEmail from '~/icons/email.svg'
import IconRss from '~/icons/rss.svg'

interface Props {
  socialLinks: SocialLinks
}

const { socialLinks } = Astro.props
---

<div class="social-links">
  {
    socialLinks.github && (
      <a
        href={socialLinks.github}
        target="_blank"
        rel="noopener noreferrer"
        class="social-link"
      >
        <span class="sr-only">GitHub</span>
        <IconGithub class="size-7" />
      </a>
    )
  }
  {
    socialLinks.bluesky && (
      <a
        href={socialLinks.bluesky}
        target="_blank"
        rel="noopener noreferrer"
        class="social-link"
      >
        <span class="sr-only">Bluesky</span>
        <IconBluesky class="size-7" />
      </a>
    )
  }
  {
    socialLinks.linkedin && (
      <a
        href={socialLinks.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="social-link"
      >
        <span class="sr-only">LinkedIn</span>
        <IconLinkedin class="size-7" />
      </a>
    )
  }
  {
    socialLinks.email && (
      <a
        href={`mailto:${socialLinks.email}`}
        target="_blank"
        rel="noopener noreferrer"
        class="social-link"
      >
        <span class="sr-only">Email</span>
        <IconEmail class="size-7" />
      </a>
    )
  }
  {
    socialLinks.mastodon && (
      <>
        <a
          href={socialLinks.mastodon}
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
        >
          <span class="sr-only">Mastodon</span>
          <IconMastodon class="size-7" />
        </a>

        <a style="display:none;" rel="me" href="https://dotnet.social/@davidpine">
          Mastodon
        </a>
      </>
    )
  }
  {
    socialLinks.twitter && (
      <a
        href={socialLinks.twitter}
        target="_blank"
        rel="noopener noreferrer"
        class="social-link"
      >
        <span class="sr-only">Twitter</span>
        <IconTwitter class="size-7" />
      </a>
    )
  }
  {
    socialLinks.rss && (
      <a href="/rss.xml" class="social-link">
        <span class="sr-only">RSS</span>
        <IconRss class="size-7" />
      </a>
    )
  }
</div>

<style>
  .social-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-start;
    gap: 0.85rem;
    width: 100%;
    max-width: 100%;
    margin-block: 0.5rem;
    padding: 0;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.55rem;
    border: 2px solid var(--retro-border);
    background: var(--theme-background);
    box-shadow: var(--retro-shadow-sm);
    color: var(--retro-secondary);
    text-decoration: none;
    transition:
      translate 0.12s ease,
      box-shadow 0.12s ease,
      background 0.12s ease,
      color 0.12s ease;
  }

  .social-link:nth-child(4n + 1) {
    color: var(--retro-primary);
  }
  .social-link:nth-child(4n + 2) {
    color: var(--retro-secondary);
  }
  .social-link:nth-child(4n + 3) {
    color: var(--retro-green);
  }
  .social-link:nth-child(4n + 4) {
    color: var(--retro-purple);
  }

  .social-link:hover,
  .social-link:focus-visible {
    translate: -2px -2px;
    background: var(--retro-secondary);
    color: var(--retro-on-accent);
    box-shadow: var(--retro-shadow);
    outline: none;
  }

  .social-link :global(svg) {
    display: block;
  }
</style>
