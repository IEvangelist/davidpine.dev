---
import { renderMermaid, THEMES } from 'beautiful-mermaid'

interface Props {
  chart: string
  theme?: keyof typeof THEMES
  alt?: string
}

const { chart, theme = 'dracula', alt = 'Mermaid diagram' } = Astro.props
const svg = await renderMermaid(chart, { ...THEMES[theme], transparent: true })
const viewBox = svg.match(/viewBox="[\d.-]+ [\d.-]+ ([\d.]+) ([\d.]+)"/)
const sourceWidth = Number(viewBox?.[1] ?? 1600)
const sourceHeight = Number(viewBox?.[2] ?? 900)
const galleryWidth = Math.max(1600, Math.round(sourceWidth))
const galleryHeight = Math.round((sourceHeight / sourceWidth) * galleryWidth)
const gallerySvg = svg
  .replace(/width="[\d.]+"/, `width="${galleryWidth}"`)
  .replace(/height="[\d.]+"/, `height="${galleryHeight}"`)
const gallerySource = `data:image/svg+xml;charset=utf-8,${encodeURIComponent(gallerySvg)}`
---

<figure class="mermaid-diagram" data-alt={alt}>
  <a
    class="post-gallery-item mermaid-gallery-link"
    href={gallerySource}
    data-sub-html={alt}
    data-lg-size={`${galleryWidth}-${galleryHeight}`}
    aria-label={`Open full-size diagram: ${alt}`}
  >
    <div role="img" aria-label={alt} set:html={svg} />
  </a>
</figure>

<style>
  .mermaid-diagram {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    margin: 1.5rem 0;
  }

  .mermaid-gallery-link {
    display: block;
    width: 100%;
    cursor: zoom-in;
    transition: opacity 0.2s ease;
  }

  .mermaid-gallery-link:hover {
    opacity: 0.85;
  }

  .mermaid-gallery-link:focus-visible {
    outline: 2px solid var(--theme-accent);
    outline-offset: 4px;
  }

  .mermaid-gallery-link :global(svg) {
    width: 100%;
    max-width: 100%;
    height: auto;
  }
</style>
