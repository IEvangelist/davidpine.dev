---
import siteConfig from '~/site.config'
import SocialLinks from '~/components/SocialLinks.astro'

const currentYear = new Date().getFullYear()
---

<footer class="site-footer">
  <section class="site-footer-hero" aria-label="Footer">
    <p class="site-footer-eyebrow">Thanks for stopping by</p>
    <h2>Curious notes, kind code, shared lessons.</h2>
    <p>
      Notes, talks, projects, and tiny experiments from {siteConfig.author} — wrapped in a little
      retro terminal joy.
    </p>
  </section>

  <div class="site-footer-grid">
    <section class="site-footer-card">
      <h3>Explore</h3>
      <nav aria-label="Footer navigation">
        {
          siteConfig.navLinks.map((link) => (
            <a
              href={link.url}
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'noopener noreferrer' : undefined}
            >
              {link.name}
            </a>
          ))
        }
      </nav>
    </section>

    {
      siteConfig.socialLinks && (
        <section class="site-footer-card site-footer-socials">
          <h3>Connect</h3>
          <p>Find me around the web, say hello, or follow along with the feed.</p>
          <SocialLinks socialLinks={siteConfig.socialLinks} />
        </section>
      )
    }

    <section class="site-footer-card">
      <h3>Colophon</h3>
      <p>
        Powered by <a target="_blank" rel="noopener noreferrer" href="https://astro.build"
          >Astro</a
        > and a healthy amount of tinkering.
      </p>
      <a
        class="site-footer-status"
        target="_blank"
        rel="noopener noreferrer"
        href="https://stats.uptimerobot.com/ZxMLuZOh33"
      >
        <span aria-hidden="true"></span>
        Uptime
      </a>
    </section>
  </div>

  <div class="site-footer-bottom">
    <span>{siteConfig.author} © {currentYear}</span>
    <span><kbd>Ctrl</kbd>/<kbd>⌘</kbd> <kbd>K</kbd> opens search</span>
  </div>
</footer>

<style>
  .site-footer {
    display: grid;
    gap: 1.25rem;
    margin-top: clamp(1.75rem, 3.5vw, 2.5rem);
    border: 2px solid var(--retro-border);
    background:
      linear-gradient(
        135deg,
        color-mix(in oklab, var(--retro-primary) 14%, transparent),
        transparent 48%
      ),
      var(--retro-panel);
    box-shadow: var(--retro-shadow);
    color: var(--theme-foreground);
    padding: clamp(1rem, 4vw, 1.5rem);
  }

  .site-footer-hero {
    display: grid;
    gap: 0.75rem;
    border: 2px solid var(--retro-border);
    background: var(--theme-background);
    padding: clamp(1rem, 4vw, 1.5rem);
  }

  .site-footer-eyebrow,
  .site-footer h2,
  .site-footer h3,
  .site-footer p {
    margin: 0;
  }

  .site-footer-eyebrow {
    color: var(--retro-secondary);
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .site-footer h2 {
    max-width: 24ch;
    color: var(--retro-primary);
    font-size: clamp(1.9rem, 4.6vw, 3rem);
    font-weight: 900;
    letter-spacing: 0.04em;
    line-height: 1.04;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .site-footer p {
    max-width: 62ch;
    color: var(--theme-text-light);
    line-height: 1.6;
  }

  .site-footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 1rem;
  }

  .site-footer-card:first-child {
    grid-row: span 2;
  }

  .site-footer-card {
    display: grid;
    align-content: start;
    gap: 1rem;
    min-width: 0;
    border: 2px solid var(--retro-border);
    background: color-mix(in oklab, var(--retro-panel) 88%, var(--theme-foreground) 12%);
    padding: 1rem;
  }

  .site-footer-card h3 {
    color: var(--retro-secondary);
    font-size: 1rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .site-footer-card nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .site-footer a {
    color: var(--theme-foreground);
    font-weight: 800;
    text-decoration-color: var(--retro-secondary);
    text-decoration-thickness: 2px;
    text-underline-offset: 0.25em;
  }

  .site-footer-card nav a,
  .site-footer-status {
    display: inline-flex;
    align-items: center;
    border: 2px solid var(--retro-border);
    background: var(--retro-primary);
    box-shadow: var(--retro-shadow-sm);
    color: var(--retro-on-accent);
    padding: 0.45rem 0.65rem;
    text-decoration: none;
    text-transform: uppercase;
  }

  .site-footer-card nav a:hover,
  .site-footer-card nav a:focus-visible,
  .site-footer-status:hover,
  .site-footer-status:focus-visible {
    translate: -2px -2px;
    background: var(--retro-secondary);
    box-shadow: var(--retro-shadow);
    outline: none;
  }

  .site-footer-status {
    width: fit-content;
    gap: 0.5rem;
  }

  .site-footer-status span {
    width: 0.75rem;
    height: 0.75rem;
    border: 2px solid var(--retro-border);
    background: var(--retro-green);
    box-shadow: var(--retro-shadow-sm);
  }

  .site-footer-socials :global(> div) {
    display: flex;
    flex-wrap: wrap;
    width: auto;
    max-width: none;
    justify-content: flex-start;
    gap: 0.75rem;
  }

  .site-footer-socials :global(.social-link) {
    display: inline-flex;
    border: 2px solid var(--retro-border);
    background: var(--theme-background);
    box-shadow: var(--retro-shadow-sm);
    color: var(--retro-secondary);
    padding: 0.45rem;
  }

  .site-footer-socials :global(.social-link:hover),
  .site-footer-socials :global(.social-link:focus-visible) {
    translate: -2px -2px;
    background: var(--retro-secondary);
    color: var(--retro-on-accent);
    box-shadow: var(--retro-shadow);
    outline: none;
  }

  .site-footer-bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    border-top: 2px solid var(--retro-border);
    color: var(--theme-text-light);
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    padding-top: 1rem;
    text-transform: uppercase;
  }

  .site-footer kbd {
    display: inline-flex;
    min-width: 1.4rem;
    justify-content: center;
    border: 2px solid var(--retro-border);
    background: var(--theme-background);
    box-shadow: var(--retro-shadow-sm);
    color: var(--theme-foreground);
    font: inherit;
    margin-inline: 0.12rem;
    padding: 0.05rem 0.28rem;
  }

  @media (max-width: 768px) {
    .site-footer-grid {
      grid-template-columns: 1fr;
    }

    .site-footer-card:first-child {
      grid-row: auto;
    }

    .site-footer-bottom {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
