---
import siteConfig from '~/site.config'
import SocialLinks from '~/components/SocialLinks.astro'
---

<footer
  class="mt-auto pt-9 md:pt-11 grow-0 flex flex-col gap-6 items-center justify-between max-w-full text-foreground/80"
>
  {siteConfig.socialLinks && <SocialLinks socialLinks={siteConfig.socialLinks} />}
  <div class="flex flex-col md:flex-row flex-wrap flex-1 items-center justify-center">
    <span class="my-1">
      {siteConfig.author} © 2025
    </span>
    <span class="mx-5 hidden md:block"> :: </span>
    <span class="my-1">
      Powered by <a
        class="underline"
        target="_blank"
        rel="noopener noreferrer"
        href="https://astro.build">Astro</a
      >
    </span>
    <span class="mx-5 hidden md:block"> :: </span>
    <span class="my-1">
      <a
        class="inline-flex items-center gap-2 underline decoration-[#3BD671]/50 underline-offset-4"
        target="_blank"
        rel="noopener noreferrer"
        href="https://stats.uptimerobot.com/ZxMLuZOh33"
      >
        <span
          aria-hidden="true"
          class="inline-flex h-3 w-3 rounded-full bg-[#3BD671] shadow-[0_0_10px_rgba(59,214,113,0.65)]"
        ></span>
        <span class="text-[#3BD671]">Uptime</span></a
      >
    </span>
  </div>
</footer>
