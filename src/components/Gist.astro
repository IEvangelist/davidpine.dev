---
interface Props {
  id: string
  file?: string
}

const { id, file } = Astro.props
const gistUrl = file
  ? `https://gist.github.com/${id}.js?file=${file}`
  : `https://gist.github.com/${id}.js`
---

<div class="gist-wrapper">
  <div class="gist-spinner" id={`spinner-${id.replace(/\//g, '-')}`}>
    <svg class="spinner-icon" viewBox="0 0 50 50">
      <circle class="spinner-path" cx="25" cy="25" r="20" fill="none" stroke-width="4"
      ></circle>
    </svg>
    <p>Loading content...</p>
  </div>
  <div class="gist-container" id={`gist-${id.replace(/\//g, '-')}`}></div>
</div>

<script is:inline define:vars={{ id, file }}>
  ;(function () {
    const gistId = id.replace(/\//g, '-')
    const spinner = document.getElementById(`spinner-${gistId}`)
    const container = document.getElementById(`gist-${gistId}`)

    // Use jsonp callback approach to load gist
    const callbackName = `gist_callback_${gistId.replace(/-/g, '_')}`

    // Override document.write temporarily
    const originalWrite = document.write
    let gistContent = ''

    document.write = function (content) {
      gistContent += content
    }

    // Create script element
    const script = document.createElement('script')
    const fileParam = file ? `?file=${file}` : ''
    script.src = `https://gist.github.com/${id}.js${fileParam}`

    const startTime = Date.now()

    script.onload = () => {
      // Restore original document.write
      document.write = originalWrite

      // Calculate how long to wait to meet minimum display time
      const elapsed = Date.now() - startTime
      const minDelay = 750
      const remainingDelay = Math.max(0, minDelay - elapsed)

      // Insert the captured content after minimum delay
      setTimeout(() => {
        if (gistContent) {
          container.innerHTML = gistContent
          spinner.style.display = 'none'
          container.style.opacity = '1'
        } else {
          spinner.innerHTML =
            '<p style="color: var(--theme-text-light);">Failed to load content. Please try again later.</p>'
        }
      }, remainingDelay)
    }

    script.onerror = () => {
      document.write = originalWrite
      if (spinner) {
        spinner.innerHTML =
          '<p style="color: var(--theme-text-light);">Failed to load content. Please try again later.</p>'
      }
    }

    // Append script to head to load the gist
    document.head.appendChild(script)
  })()
</script>

<style>
  .gist-wrapper {
    position: relative;
    margin: 0;
    max-width: 100%;
  }

  .gist-spinner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem 1rem;
    gap: 1rem;
  }

  .gist-spinner p {
    color: var(--theme-text-light);
    font-size: 0.95rem;
  }

  .spinner-icon {
    width: 3rem;
    height: 3rem;
    animation: rotate 2s linear infinite;
  }

  .spinner-path {
    stroke: var(--theme-accent);
    stroke-linecap: round;
    animation: dash 1.5s ease-in-out infinite;
  }

  @keyframes rotate {
    100% {
      transform: rotate(360deg);
    }
  }

  @keyframes dash {
    0% {
      stroke-dasharray: 1, 150;
      stroke-dashoffset: 0;
    }
    50% {
      stroke-dasharray: 90, 150;
      stroke-dashoffset: -35;
    }
    100% {
      stroke-dasharray: 90, 150;
      stroke-dashoffset: -124;
    }
  }

  .gist-container {
    max-width: 100%;
    opacity: 0;
    overflow-x: hidden;
    transition: opacity 0.3s ease-in;
  }

  /* Base gist container */
  .gist-container :global(.gist) {
    font-family: var(--font-body) !important;
    font-size: 0.95rem !important;
    margin: 0 !important;
  }

  /* Gist file wrapper */
  .gist-container :global(.gist .gist-file) {
    max-width: 100% !important;
    border: 0 !important;
    border-radius: 0 !important;
    background: var(--retro-panel) !important;
    box-shadow: var(--retro-shadow) !important;
    overflow: hidden !important;
  }

  /* Remove GitHub's .file my-2 margin that created an empty band inside the frame */
  .gist-container :global(.gist .file) {
    margin: 0 !important;
  }

  /* Gist data container */
  .gist-container :global(.gist .gist-data) {
    max-width: 100% !important;
    border-radius: 0 !important;
    background: var(--retro-panel) !important;
    border-bottom: none !important;
    overflow: auto !important;
  }

  /* Markdown body */
  .gist-container :global(.gist .markdown-body) {
    max-width: 100% !important;
    overflow-x: hidden !important;
    background: var(--retro-panel) !important;
    color: var(--theme-foreground) !important;
    padding: 0 !important;
  }

  /* Headings */
  .gist-container :global(.gist .markdown-body .markdown-heading) {
    margin: 0 !important;
    padding: 0 !important;
  }

  .gist-container :global(.gist .markdown-body h2),
  .gist-container :global(.gist .markdown-body .markdown-heading h2) {
    border: 2px solid var(--retro-border) !important;
    border-bottom: 0 !important;
    background: color-mix(
      in oklab,
      var(--retro-panel) 86%,
      var(--theme-foreground) 14%
    ) !important;
    box-shadow: none !important;
    color: var(--retro-primary) !important;
    padding: 0.65rem 0.85rem !important;
    margin-top: 0 !important;
    margin-bottom: 0 !important;
    font-size: clamp(1.25rem, 2vw, 1.6rem) !important;
    font-weight: 900 !important;
    letter-spacing: 0.08em !important;
    line-height: 1.1 !important;
    text-transform: uppercase !important;
  }

  .gist-container :global(.gist .markdown-body h2:first-child) {
    margin-top: 0 !important;
  }

  /* Hide anchor links */
  .gist-container :global(.gist .markdown-body .anchor),
  .gist-container :global(.gist .markdown-body .octicon) {
    display: none !important;
  }

  /* Table wrapper */
  .gist-container :global(.gist markdown-accessiblity-table) {
    box-sizing: border-box !important;
    display: block !important;
    max-width: 100% !important;
    width: 100% !important;
    margin: 0 !important;
    overflow-x: auto !important;
    border-radius: 0 !important;
  }

  .gist-container :global(.gist markdown-accessiblity-table + .markdown-heading) {
    margin-top: 0 !important;
  }

  /* Table styling */
  .gist-container :global(.gist table) {
    width: 100% !important;
    table-layout: fixed !important;
    border-collapse: separate !important;
    border-spacing: 0 !important;
    border: 2px solid var(--retro-border) !important;
    border-top-width: 2px !important;
    border-radius: 0 !important;
    background: var(--retro-panel) !important;
    color: var(--theme-text) !important;
    font-size: clamp(0.92rem, 1.1vw, 1rem) !important;
    line-height: 1.55 !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* Table head */
  .gist-container :global(.gist thead) {
    border-radius: 0 !important;
    background: var(--retro-primary) !important;
  }

  .gist-container :global(.gist thead tr) {
    border-radius: 0 !important;
    background: var(--retro-primary) !important;
  }

  .gist-container :global(.gist th) {
    padding: 0.95rem 1rem !important;
    text-align: left !important;
    font-weight: 800 !important;
    background: var(--retro-primary) !important;
    color: var(--retro-on-accent) !important;
    border: 0 !important;
    border-right: 2px solid var(--retro-border) !important;
    border-bottom: 2px solid var(--retro-border) !important;
    border-radius: 0 !important;
    text-transform: uppercase !important;
    font-size: 0.85rem !important;
    letter-spacing: 0.08em !important;
    vertical-align: middle !important;
  }

  .gist-container :global(.gist th:last-child) {
    border-right: 0 !important;
  }

  /* Table body */
  .gist-container :global(.gist tbody) {
    border-radius: 0 !important;
    background: var(--retro-panel) !important;
  }

  .gist-container :global(.gist tbody tr) {
    border-radius: 0 !important;
    transition: background-color 0.2s ease !important;
  }

  .gist-container :global(.gist tbody tr:nth-child(even) td) {
    background: color-mix(
      in oklab,
      var(--retro-panel) 90%,
      var(--theme-foreground) 10%
    ) !important;
  }

  .gist-container :global(.gist tbody tr:hover td) {
    background: var(--theme-bg-hover) !important;
  }

  .gist-container :global(.gist tbody tr:last-child) {
    border-bottom: none !important;
  }

  .gist-container :global(.gist td) {
    padding: 1rem !important;
    text-align: left !important;
    border: 0 !important;
    border-right: 2px solid var(--retro-border) !important;
    border-bottom: 2px solid var(--retro-border) !important;
    border-radius: 0 !important;
    color: var(--theme-foreground) !important;
    background: var(--retro-panel) !important;
    vertical-align: top !important;
  }

  .gist-container :global(.gist td:last-child) {
    border-right: 0 !important;
  }

  .gist-container :global(.gist tbody tr:last-child td) {
    border-bottom: 0 !important;
  }

  .gist-container :global(.gist th:first-child),
  .gist-container :global(.gist td:first-child) {
    width: 10rem !important;
    white-space: nowrap !important;
  }

  .gist-container :global(.gist th:nth-child(2)),
  .gist-container :global(.gist td:nth-child(2)) {
    width: 32% !important;
  }

  /* Links */
  .gist-container :global(.gist td a),
  .gist-container :global(.gist .markdown-body a) {
    color: var(--retro-primary) !important;
    font-weight: 800 !important;
    text-decoration-color: var(--retro-secondary) !important;
    text-decoration-line: underline !important;
    text-decoration-thickness: 2px !important;
    text-underline-offset: 0.22em !important;
    transition:
      background-color 0.2s ease,
      color 0.2s ease !important;
  }

  .gist-container :global(.gist td a:hover),
  .gist-container :global(.gist .markdown-body a:hover) {
    background: var(--retro-primary) !important;
    color: var(--retro-on-accent) !important;
    text-decoration: none !important;
  }

  /* Code blocks */
  .gist-container :global(.gist td code),
  .gist-container :global(.gist .markdown-body code) {
    background: var(--theme-code-inline-bg) !important;
    padding: 0.125rem 0.375rem !important;
    border: 2px solid var(--retro-border) !important;
    border-radius: 0 !important;
    font-size: 0.9em !important;
    color: var(--theme-foreground) !important;
    font-family: var(--font-mono) !important;
  }

  /* Gist meta footer */
  .gist-container :global(.gist .gist-meta) {
    background: color-mix(
      in oklab,
      var(--retro-panel) 86%,
      var(--theme-foreground) 14%
    ) !important;
    color: var(--theme-text-light) !important;
    border: 2px solid var(--retro-border) !important;
    border-top: 2px solid var(--retro-border) !important;
    padding: 0.75rem 1rem !important;
    font-size: 0.85rem !important;
  }

  .gist-container :global(.gist .gist-meta a) {
    color: var(--theme-accent) !important;
    text-decoration: none !important;
  }

  .gist-container :global(.gist .gist-meta a:hover) {
    color: var(--theme-text) !important;
    text-decoration: underline !important;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .gist-container :global(.gist .markdown-body) {
      padding: 0 !important;
    }

    .gist-container :global(.gist table) {
      font-size: 0.85rem !important;
      min-width: 42rem !important;
    }

    .gist-container :global(.gist th),
    .gist-container :global(.gist td) {
      padding: 0.75rem 0.5rem !important;
    }
  }
</style>
