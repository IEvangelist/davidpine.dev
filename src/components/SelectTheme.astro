---
import IconPalette from '~/icons/palette.svg'
import siteConfig from '~/site.config'
import { resolveThemeColorStyles } from '~/utils'

function kebabToTitleCase(str: string): string {
  return str
    .split('-') // Split the string into words
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1)) // Capitalize each word
    .join(' ') // Join the words with a space
}

const resolvedThemePreviews = await resolveThemeColorStyles(
  siteConfig.themes.include,
  siteConfig.themes.overrides,
)

const themePreviewCss = Object.entries(resolvedThemePreviews)
  .map(([theme, colors]) => {
    return [
      `select-theme .theme-option[data-theme="${theme}"] {`,
      `--preview-background: ${colors.background};`,
      `--preview-foreground: ${colors.foreground};`,
      `--preview-accent: ${colors.accent};`,
      `--preview-heading: ${colors.heading2};`,
      `--preview-green: ${colors.green};`,
      `--preview-red: ${colors.red};`,
      '}',
    ].join('\n')
  })
  .join('\n')
---

<select-theme class="ms-auto" id="theme-selector">
  <button class="theme-open-button" aria-label="Select theme" data-open-modal disabled>
    <IconPalette class="size-6 text-accent" />
    <span class="sr-only">Select Theme</span>
  </button>
  <dialog aria-labelledby="theme-dialog-title" class="theme-dialog">
    <div class="dialog-frame theme-dialog-frame">
      <button aria-label="Close theme picker" class="theme-close-button" data-close-modal>
        <span aria-hidden="true">X</span>
      </button>
      <header class="theme-dialog-header">
        <p id="theme-dialog-title">// Theme</p>
        <span>Pick a palette. Ctrl/⌘ K is reserved for search.</span>
      </header>
      <ul id="theme-change-list" class="theme-list">
        {
          siteConfig.themes.include.map((theme) => (
            <li>
              <button class="theme-option" type="button" data-theme={theme}>
                <span class="theme-option-preview" aria-hidden="true">
                  <span />
                  <span />
                  <span />
                </span>
                <span class="theme-option-label">{kebabToTitleCase(theme)}</span>
                <small>Current</small>
              </button>
            </li>
          ))
        }
      </ul>
    </div>
  </dialog>
</select-theme>

<style is:inline set:html={themePreviewCss}></style>

<style>
  .theme-open-button,
  .theme-close-button {
    display: inline-flex;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    border: 0;
    background: transparent;
    color: var(--theme-accent);
  }

  .theme-open-button {
    border-radius: 0;
  }

  .theme-open-button :global(svg) {
    transform: translateY(1px);
  }

  .theme-open-button:hover,
  .theme-open-button:focus-visible {
    color: var(--retro-secondary);
    outline: none;
  }

  .theme-dialog {
    width: min(92vw, 34rem);
    max-height: min(82vh, 52rem);
    margin: clamp(2rem, 8vh, 4rem) auto auto;
    padding: 0;
    overflow: hidden;
    border: 2px solid var(--retro-border);
    border-radius: 0;
    background: var(--retro-panel);
    color: var(--theme-foreground);
    box-shadow: 8px 8px 0 0 var(--retro-shadow-color);
  }

  .theme-dialog::backdrop {
    background: color-mix(in oklab, #000 52%, transparent);
    backdrop-filter: blur(2px);
  }

  .theme-dialog-frame {
    position: relative;
    display: grid;
    max-height: inherit;
    grid-template-rows: auto minmax(0, 1fr);
    gap: 1rem;
    padding: clamp(1rem, 3vw, 1.4rem);
  }

  .theme-close-button {
    position: absolute;
    right: 0.65rem;
    top: 0.65rem;
    width: 2.2rem;
    height: 2.2rem;
    border: 2px solid var(--retro-border);
    background: var(--retro-panel);
    box-shadow: var(--retro-shadow-sm);
    font-size: 1rem;
    font-weight: 900;
    line-height: 1;
    padding: 0.25rem;
    text-transform: uppercase;
  }

  .theme-close-button:hover,
  .theme-close-button:focus-visible {
    translate: -2px -2px;
    background: var(--retro-secondary);
    color: var(--retro-on-accent);
    box-shadow: var(--retro-shadow);
    outline: none;
  }

  .theme-dialog-header {
    display: grid;
    gap: 0.35rem;
    border-bottom: 2px solid var(--retro-border);
    padding: 0 2.5rem 0.9rem 0;
  }

  .theme-dialog-header p,
  .theme-dialog-header span,
  .theme-list {
    margin: 0;
  }

  .theme-dialog-header p {
    color: var(--retro-secondary);
    font-size: 1.15rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    line-height: 1;
    text-transform: uppercase;
  }

  .theme-dialog-header span {
    color: var(--theme-text-light);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .theme-list {
    display: grid;
    gap: 0.6rem;
    min-height: 0;
    overflow: auto;
    padding: 0.15rem 0.35rem 0.35rem 0;
    list-style: none;
  }

  .theme-option {
    --preview-background: var(--theme-background);
    --preview-foreground: var(--theme-foreground);
    --preview-accent: var(--theme-accent);
    --preview-heading: var(--theme-heading2);
    --preview-green: var(--theme-green);
    --preview-red: var(--theme-red);
    display: grid;
    width: 100%;
    min-height: 2.65rem;
    align-items: center;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.85rem;
    border: 2px solid var(--preview-foreground);
    border-radius: 0;
    background:
      linear-gradient(90deg, var(--preview-accent) 0 0.45rem, transparent 0.45rem),
      var(--preview-background);
    color: var(--preview-foreground);
    box-shadow: var(--retro-shadow-sm);
    font-weight: 900;
    letter-spacing: 0.1em;
    padding: 0.65rem 0.85rem;
    text-align: left;
    text-transform: uppercase;
  }

  .theme-option-preview {
    display: grid;
    width: 3.25rem;
    gap: 0.18rem;
    border: 2px solid var(--preview-foreground);
    background: var(--preview-background);
    padding: 0.28rem;
  }

  .theme-option-preview span {
    display: block;
    height: 0.32rem;
    background: var(--preview-accent);
  }

  .theme-option-preview span:nth-child(2) {
    width: 72%;
    background: var(--preview-heading);
  }

  .theme-option-preview span:nth-child(3) {
    width: 48%;
    background: var(--preview-green);
  }

  .theme-option-label {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .theme-option small {
    display: none;
    border: 2px solid var(--preview-foreground);
    background: var(--preview-accent);
    color: var(--preview-background);
    font-size: 0.65rem;
    padding: 0.1rem 0.3rem;
  }

  .theme-option:hover,
  .theme-option:focus-visible {
    translate: -2px -2px;
    box-shadow: var(--retro-shadow);
    outline: 3px solid var(--preview-accent);
    outline-offset: 3px;
  }

  .theme-option.current-theme,
  .theme-option[data-current='true'] {
    outline: 3px solid var(--preview-accent);
    outline-offset: 3px;
  }

  .theme-option.current-theme small,
  .theme-option[data-current='true'] small {
    display: inline-flex;
  }
</style>

<script>
  class SelectTheme extends HTMLElement {
    #closeBtn: HTMLButtonElement | null
    #dialog: HTMLDialogElement | null
    #dialogFrame: HTMLDivElement | null
    #openBtn: HTMLButtonElement | null
    #controller: AbortController

    constructor() {
      super()
      this.#openBtn = this.querySelector<HTMLButtonElement>('button[data-open-modal]')
      this.#closeBtn = this.querySelector<HTMLButtonElement>('button[data-close-modal]')
      this.#dialog = this.querySelector<HTMLDialogElement>('dialog')
      this.#dialogFrame = this.querySelector('.dialog-frame')
      this.#controller = new AbortController()

      // Set up events
      if (this.#openBtn) {
        this.#openBtn.addEventListener('click', this.openModal)
        this.#openBtn.disabled = false
      } else {
        console.warn('Select theme button not found')
      }

      if (this.#closeBtn) {
        this.#closeBtn.addEventListener('click', this.closeModal)
      } else {
        console.warn('Close button not found')
      }

      if (this.#dialog) {
        this.#dialog.addEventListener('close', () => {
          window.removeEventListener('click', this.onWindowClick)
          const body = document.querySelector('body')
          body?.classList.remove('overflow-hidden')
        })
      } else {
        console.warn('Dialog not found')
      }

      let themeChangeButtons = this.querySelectorAll('#theme-change-list button')
      themeChangeButtons?.forEach((button) => {
        button.addEventListener('click', (ev) => {
          ev.preventDefault()
          let themeId = button.getAttribute('data-theme')
          if (themeId) {
            document.documentElement.setAttribute('data-theme', themeId)
            localStorage.setItem('data-theme', themeId)
            this.closeModal()
          }
        })
      })
    }

    disconnectedCallback() {
      this.#controller.abort()
    }

    openModal = (event?: MouseEvent) => {
      if (!this.#dialog) {
        console.warn('Dialog not found')
        return
      }
      this.highlightCurrentTheme()
      document
        .querySelectorAll<HTMLDialogElement>('site-search dialog[open]')
        .forEach((dialog) => dialog.close())

      const body = document.querySelector('body')
      body?.classList.add('overflow-hidden')
      if (!this.#dialog.open) {
        this.#dialog.showModal()
      }
      requestAnimationFrame(() => {
        this.querySelector<HTMLButtonElement>('.current-theme')?.focus()
      })
      event?.stopPropagation()
      window.addEventListener('click', this.onWindowClick, {
        signal: this.#controller.signal,
      })
    }

    closeModal = () => {
      this.#dialog?.close()
      this.#openBtn?.focus()
    }

    onWindowClick = (event: MouseEvent) => {
      // check if it's a link
      const isLink = 'href' in (event.target || {})
      // make sure the click is either a link or outside of the dialog
      if (
        isLink ||
        (document.body.contains(event.target as Node) &&
          !this.#dialogFrame?.contains(event.target as Node))
      ) {
        this.closeModal()
      }
    }

    highlightCurrentTheme() {
      const currentTheme = document.documentElement.getAttribute('data-theme')
      if (!currentTheme) {
        console.warn('No theme set in data-theme attribute.')
        return
      }
      const themeChangeListItems = this.querySelectorAll('#theme-change-list li')
      themeChangeListItems?.forEach((listItem) => {
        let button = listItem.querySelector('button')
        if (!button) {
          console.warn('No button found in theme change list item.')
          return
        }
        if (button.getAttribute('data-theme') === currentTheme) {
          button.classList.add('current-theme')
          button.setAttribute('data-current', 'true')
          button.setAttribute('aria-current', 'true')
        } else {
          button.classList.remove('current-theme')
          button.removeAttribute('data-current')
          button.removeAttribute('aria-current')
        }
      })
    }
  }

  customElements.define('select-theme', SelectTheme)
</script>
