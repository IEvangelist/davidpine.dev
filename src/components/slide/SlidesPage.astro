---
import SlideCard, { type Slide } from './SlideCard.astro'

interface Tag {
  tag: string
  count?: number
  size: number
}

interface Props {
  slides: Slide[]
  tags: Tag[]
  tag: string
}

const { slides, tags, tag } = Astro.props
---

<div class="slides-browser">
  {
    tags && tags.length > 0 && (
      <nav class="slide-filters" aria-label="Filter slides by topic">
        <a
          href="/slides"
          data-slide-filter
          data-tag=""
          data-active={!tag ? 'true' : 'false'}
          aria-pressed={!tag ? 'true' : 'false'}
          class:list={['slide-filter', !tag ? 'is-active' : '']}
        >
          All
        </a>
        {tags.map((t) => (
          <a
            href={`/slides?tag=${encodeURIComponent(t.tag)}`}
            data-slide-filter
            data-tag={t.tag}
            data-active={tag === t.tag ? 'true' : 'false'}
            aria-pressed={tag === t.tag ? 'true' : 'false'}
            class:list={['slide-filter', tag === t.tag ? 'is-active' : '']}
          >
            <span>{t.tag}</span>
            {t.count && <span class="slide-filter-count">({t.count})</span>}
          </a>
        ))}
      </nav>
    )
  }
  <div class="slides-grid">
    {
      slides.map((slide) => (
        <a
          href={`/slides/${slide.id}`}
          class="slide-card-link"
          data-slide-card
          data-tags={JSON.stringify(slide.tags ?? [])}
        >
          <SlideCard slide={slide} />
        </a>
      ))
    }
  </div>

  {
    (
      <div class:list={['slides-empty', slides.length > 0 && 'hidden']} data-no-slides>
        No slides found
      </div>
    )
  }
</div>

<script>
  const activeFilterClasses = ['is-active']

  function getSelectedSlideTags() {
    const tags = new URLSearchParams(window.location.search).getAll('tag')
    return [...new Set(tags.filter(Boolean))]
  }

  function parseSlideTags(card: Element) {
    try {
      const tags = JSON.parse(card.getAttribute('data-tags') ?? '[]')
      return Array.isArray(tags) ? tags : []
    } catch {
      return []
    }
  }

  function updateSlideFilters() {
    const selectedTags = getSelectedSlideTags()
    const cards = document.querySelectorAll('[data-slide-card]')
    const filters = document.querySelectorAll('[data-slide-filter]')
    const noSlides = document.querySelector('[data-no-slides]')
    let visibleCards = 0

    cards.forEach((card) => {
      const tags = parseSlideTags(card)
      const isVisible =
        selectedTags.length === 0 || selectedTags.every((tag) => tags.includes(tag))
      card.classList.toggle('hidden', !isVisible)
      visibleCards += isVisible ? 1 : 0
    })

    filters.forEach((filter) => {
      const filterTag = filter.getAttribute('data-tag') ?? ''
      const isActive = filterTag
        ? selectedTags.includes(filterTag)
        : selectedTags.length === 0

      filter.classList.toggle(activeFilterClasses[0], isActive)
      filter.setAttribute('data-active', isActive ? 'true' : 'false')

      if (isActive) {
        filter.setAttribute('aria-pressed', 'true')
      } else {
        filter.setAttribute('aria-pressed', 'false')
      }
    })

    noSlides?.classList.toggle('hidden', visibleCards > 0)
  }

  function handleSlideFilterClick(event: MouseEvent) {
    const target = event.target instanceof Element ? event.target : null
    const filter = target?.closest('[data-slide-filter]')

    if (!(filter instanceof HTMLAnchorElement)) {
      return
    }

    event.preventDefault()
    const filterTag = filter.getAttribute('data-tag') ?? ''
    const selectedTags = new Set(getSelectedSlideTags())
    const url = new URL(window.location.href)

    url.searchParams.delete('tag')

    if (filterTag) {
      if (selectedTags.has(filterTag)) {
        selectedTags.delete(filterTag)
      } else {
        selectedTags.add(filterTag)
      }

      selectedTags.forEach((tag) => url.searchParams.append('tag', tag))
    }

    history.pushState(null, '', url.toString())
    updateSlideFilters()
  }

  if (document.documentElement.dataset.slideFiltersInitialized !== 'true') {
    document.documentElement.dataset.slideFiltersInitialized = 'true'
    document.addEventListener('click', handleSlideFilterClick)
    window.addEventListener('popstate', updateSlideFilters)
    document.addEventListener('astro:page-load', updateSlideFilters)
  }

  updateSlideFilters()
</script>

<style>
  .slides-browser {
    display: grid;
    gap: 1.5rem;
  }

  .slide-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    border: 2px solid var(--retro-border);
    background:
      linear-gradient(
        135deg,
        color-mix(in oklab, var(--retro-primary) 12%, transparent),
        transparent 52%
      ),
      var(--retro-panel);
    box-shadow: var(--retro-shadow);
    padding: clamp(0.85rem, 2vw, 1.1rem);
  }

  .slide-filter {
    display: inline-flex;
    min-height: 2.5rem;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    border: 2px solid var(--retro-border);
    background: color-mix(in oklab, var(--retro-panel) 88%, var(--theme-foreground) 12%);
    color: var(--theme-foreground);
    box-shadow: var(--retro-shadow-sm);
    font-size: 0.85rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    line-height: 1.1;
    padding: 0.65rem 0.85rem;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      translate 120ms ease,
      box-shadow 120ms ease,
      background-color 120ms ease,
      color 120ms ease;
  }

  .slide-filter:hover,
  .slide-filter:focus-visible {
    translate: -2px -2px;
    background: var(--retro-secondary);
    color: var(--retro-on-accent);
    box-shadow: var(--retro-shadow);
    outline: none;
  }

  .slide-filter.is-active,
  .slide-filter[data-active='true'] {
    background: var(--retro-primary);
    color: var(--retro-on-accent);
  }

  .slide-filter-count {
    font-size: 0.72em;
    opacity: 0.75;
  }

  .slides-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 24rem), 1fr));
    gap: 1.75rem;
    align-items: stretch;
  }

  .slide-card-link {
    display: flex;
    min-width: 0;
    color: inherit;
    text-decoration: none;
  }

  .slide-card-link.hidden {
    display: none;
  }

  .slides-empty {
    border: 2px solid var(--retro-border);
    background: var(--retro-panel);
    box-shadow: var(--retro-shadow);
    color: var(--theme-text-light);
    font-weight: 800;
    letter-spacing: 0.08em;
    padding: 3rem 1rem;
    text-align: center;
    text-transform: uppercase;
  }
</style>
