---
import { Icon } from 'astro-icon/components'

export interface Props {
  name: string
  icon: string
}

const { name, icon } = Astro.props
---

<div class="tech-badge">
  <div class="tech-icon">
    <Icon name={icon} />
  </div>
  <span>{name}</span>
</div>

<style>
  .tech-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    border: 2px solid var(--retro-border);
    border-radius: 0;
    background: var(--retro-panel);
    box-shadow: var(--retro-shadow-sm);
    color: var(--theme-foreground);
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition:
      translate 120ms ease,
      box-shadow 120ms ease,
      background-color 120ms ease,
      color 120ms ease;
    user-select: none;
    cursor: default;
  }

  .tech-badge:hover {
    translate: -2px -2px;
    background: var(--retro-secondary);
    box-shadow: var(--retro-shadow);
    color: var(--retro-on-accent);
  }

  .tech-icon {
    width: 1.5rem;
    height: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--retro-primary);
  }

  .tech-badge:hover .tech-icon {
    color: currentColor;
  }

  .tech-icon :global(svg) {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  @media (max-width: 640px) {
    .tech-badge {
      padding: 0.625rem 1rem;
      font-size: 0.875rem;
      gap: 0.5rem;
    }

    .tech-icon {
      width: 1.25rem;
      height: 1.25rem;
    }
  }
</style>
