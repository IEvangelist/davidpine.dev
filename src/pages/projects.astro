---
import Layout from '~/layouts/Layout.astro'
import PageHeader from '~/components/PageHeader.astro'

const projects = [
  {
    name: '6174',
    tagline: 'Kaprekar Explorer',
    description:
      "An animated React + Vite app that walks 4-digit seeds into Kaprekar's constant 6174 — one subtraction card at a time.",
    repoUrl: 'https://github.com/IEvangelist/6174',
    pagesUrl: 'https://ievangelist.github.io/6174/',
    lightThumbnail: '/images/projects/6174-light.png',
    darkThumbnail: '/images/projects/6174-dark.png',
    tone: '#a78bfa',
    repoPath: 'IEvangelist/6174',
  },
  {
    name: 'Azure Cosmos DB Repository .NET SDK',
    tagline: 'IRepository<T> for Cosmos DB',
    description:
      'A dependency-injection-friendly wrapper around the official Microsoft.Azure.Cosmos SDK — configure once, inject everywhere. 1.2M+ NuGet downloads.',
    repoUrl: 'https://github.com/IEvangelist/azure-cosmos-dotnet-repository',
    pagesUrl: 'https://ievangelist.github.io/azure-cosmos-dotnet-repository/',
    lightThumbnail: '/images/projects/azure-cosmos-repository-light.png',
    darkThumbnail: '/images/projects/azure-cosmos-repository-dark.png',
    tone: '#38bdf8',
    repoPath: 'IEvangelist/azure-cosmos-dotnet-repository',
  },
  {
    name: 'Nextflix',
    tagline: 'Streaming-style Next.js demo',
    description:
      'A Netflix-style streaming clone built with Next.js 15, TypeScript, Tailwind, and the TMDB API — hero trailers, hover cards, infinite browsing.',
    repoUrl: 'https://github.com/IEvangelist/nextflix',
    pagesUrl: 'https://nextflix-ai.netlify.app/',
    lightThumbnail: '/images/projects/nextflix-light.png',
    darkThumbnail: '/images/projects/nextflix-dark.png',
    tone: '#ef4444',
    repoPath: 'IEvangelist/nextflix',
  },
  {
    name: 'Resource Translator',
    tagline: 'Localize .resx with GitHub Actions',
    description:
      'A GitHub Action that translates .resx and localization resources for .NET apps — drop it in your workflow and ship multilingual builds.',
    repoUrl: 'https://github.com/IEvangelist/resource-translator',
    pagesUrl: 'https://ievangelist.github.io/resource-translator/',
    lightThumbnail: '/images/projects/resource-translator-light.png',
    darkThumbnail: '/images/projects/resource-translator-dark.png',
    tone: '#22d3ee',
    repoPath: 'IEvangelist/resource-translator',
  },
  {
    name: 'Profanity Filter',
    tagline: 'Modern .NET moderation',
    description:
      'A modern .NET profanity filtering solution with first-class source generators, customizable rules, and AOT-ready performance.',
    repoUrl: 'https://github.com/IEvangelist/profanity-filter',
    pagesUrl: 'https://ievangelist.github.io/profanity-filter/',
    lightThumbnail: '/images/projects/profanity-filter-light.png',
    darkThumbnail: '/images/projects/profanity-filter-dark.png',
    tone: '#f472b6',
    repoPath: 'IEvangelist/profanity-filter',
  },
  {
    name: 'Netlify Aspire Integration',
    tagline: 'Aspire-powered Netlify hosting',
    description:
      'A hosting integration that helps deploy Aspire-powered static experiences using Netlify — bring your AppHost, ship to the edge.',
    repoUrl: 'https://github.com/IEvangelist/netlify-aspire-integration',
    pagesUrl: 'https://ievangelist.github.io/netlify-aspire-integration/',
    lightThumbnail: '/images/projects/netlify-aspire-integration-light.png',
    darkThumbnail: '/images/projects/netlify-aspire-integration-dark.png',
    tone: '#2dd4bf',
    repoPath: 'IEvangelist/netlify-aspire-integration',
  },
  {
    name: 'Blazorators',
    tagline: 'Source-generated JS interop for Blazor',
    description:
      'Roslyn source generators that author idiomatic, strongly-typed C# wrappers around the browser’s web APIs — no hand-written IJSRuntime glue required.',
    repoUrl: 'https://github.com/IEvangelist/blazorators',
    pagesUrl: 'https://ievangelist.github.io/blazorators/',
    lightThumbnail: '/images/projects/blazorators-light.png',
    darkThumbnail: '/images/projects/blazorators-dark.png',
    tone: '#a855f7',
    repoPath: 'IEvangelist/blazorators',
  },
  {
    name: 'Bueler',
    tagline: 'Rust web framework, totally vibed',
    description:
      'Build reactive web apps entirely in Rust — fine-grained signals, zero JavaScript, direct DOM manipulation, compiled to WebAssembly. Ships with 48 components out of the box.',
    repoUrl: 'https://github.com/IEvangelist/Bueler',
    pagesUrl: 'https://ievangelist.github.io/Bueler/',
    lightThumbnail: '/images/projects/bueler-light.png',
    darkThumbnail: '/images/projects/bueler-dark.png',
    tone: '#f97316',
    repoPath: 'IEvangelist/Bueler',
  },
]
---

<Layout title="Projects" description="Featured projects by David Pine">
  <PageHeader title="Projects" />

  <article class="max-w-full py-7.5 space-y-8">
    <section class="project-intro rounded-2xl border border-accent/20 p-5 md:p-7">
      <p class="m-0 text-lg md:text-xl">
        Built in public, shipped in production — quick access to each project’s live docs
        and source.
      </p>
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="meta-chip">{projects.length} Featured Repositories</span>
        <span class="meta-chip">Live + source quick actions</span>
      </div>
    </section>

    <div class="project-list flex flex-col gap-10 md:gap-14">
      {
        projects.map((project, idx) => (
          <article
            class:list={['project-row', idx % 2 === 1 && 'project-row--reversed']}
            style={`--card-tone: ${project.tone};`}
          >
            <a
              class="image-card group/img"
              href={project.pagesUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Open ${project.name} live site`}
            >
              <img
                src={project.lightThumbnail}
                alt={`${project.name} live site screenshot in light mode`}
                class="thumb-image thumb-image-light"
                loading={idx < 2 ? 'eager' : 'lazy'}
                width="1280"
                height="720"
              />
              <img
                src={project.darkThumbnail}
                alt={`${project.name} live site screenshot in dark mode`}
                class="thumb-image thumb-image-dark"
                loading={idx < 2 ? 'eager' : 'lazy'}
                width="1280"
                height="720"
              />
            </a>

            <div class="info-panel">
              <div class="info-top">
                <span class="repo-path">
                  <svg
                    class="repo-icon"
                    viewBox="0 0 16 16"
                    width="13"
                    height="13"
                    aria-hidden="true"
                    fill="currentColor"
                  >
                    <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25a.25.25 0 0 1-.4.2l-1.45-1.087a.249.249 0 0 0-.3 0L5.4 15.7a.25.25 0 0 1-.4-.2Z" />
                  </svg>
                  {project.repoPath}
                </span>
                <span class="live-status">
                  <span class="live-dot" aria-hidden="true" />
                  Live
                </span>
              </div>

              <p class="info-tagline m-0">{project.tagline}</p>
              <h2 class="info-title m-0">{project.name}</h2>
              <p class="info-description m-0">{project.description}</p>

              <div class="info-actions">
                <a
                  href={project.pagesUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="cta cta-primary"
                >
                  <span>Open live site</span>
                  <svg
                    class="cta-icon"
                    viewBox="0 0 16 16"
                    width="13"
                    height="13"
                    aria-hidden="true"
                    fill="currentColor"
                  >
                    <path d="M3.75 2A1.75 1.75 0 0 0 2 3.75v8.5C2 13.216 2.784 14 3.75 14h8.5A1.75 1.75 0 0 0 14 12.25v-3.5a.75.75 0 0 0-1.5 0v3.5a.25.25 0 0 1-.25.25h-8.5a.25.25 0 0 1-.25-.25v-8.5a.25.25 0 0 1 .25-.25h3.5a.75.75 0 0 0 0-1.5Zm6.854-.354A.5.5 0 0 1 11 1.5h3.5a.5.5 0 0 1 .5.5V5.5a.5.5 0 0 1-.854.354L13 4.707 8.354 9.354a.5.5 0 1 1-.708-.708L12.293 4 11.146 2.854a.5.5 0 0 1-.292-.708Z" />
                  </svg>
                </a>
                <a
                  href={project.repoUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="cta cta-secondary"
                >
                  <svg
                    class="cta-icon"
                    viewBox="0 0 16 16"
                    width="13"
                    height="13"
                    aria-hidden="true"
                    fill="currentColor"
                  >
                    <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z" />
                  </svg>
                  <span>Source</span>
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </article>
</Layout>

<script>
  const root = document.documentElement
  const parseRgbColor = (value) => {
    const rgbMatch = value.match(
      /rgba?\(\s*(\d{1,3})[\s,]+(\d{1,3})[\s,]+(\d{1,3})(?:[\s,\/]+[\d.]+)?\s*\)/i,
    )
    if (rgbMatch) {
      return [Number(rgbMatch[1]), Number(rgbMatch[2]), Number(rgbMatch[3])]
    }

    const hex = value.replace('#', '').trim()
    if (/^[\da-f]{3}$/i.test(hex)) {
      return hex.split('').map((part) => Number.parseInt(part + part, 16))
    }

    if (/^[\da-f]{6}$/i.test(hex)) {
      return [
        Number.parseInt(hex.slice(0, 2), 16),
        Number.parseInt(hex.slice(2, 4), 16),
        Number.parseInt(hex.slice(4, 6), 16),
      ]
    }

    const probe = document.createElement('span')
    probe.style.color = value
    document.body.appendChild(probe)
    const computed = getComputedStyle(probe).color
    probe.remove()
    const computedMatch = computed.match(/rgb\((\d{1,3}),\s*(\d{1,3}),\s*(\d{1,3})\)/i)
    if (computedMatch) {
      return [
        Number(computedMatch[1]),
        Number(computedMatch[2]),
        Number(computedMatch[3]),
      ]
    }

    return null
  }

  const resolveThemeTone = () => {
    const rawBackground = getComputedStyle(root)
      .getPropertyValue('--theme-background')
      .trim()
    const rgb = parseRgbColor(rawBackground)

    if (!rgb) {
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
    }

    const [r, g, b] = rgb.map((channel) => {
      const normalized = channel / 255
      // WCAG 2.x relative luminance conversion from sRGB to linear RGB.
      return normalized <= 0.03928
        ? normalized / 12.92
        : ((normalized + 0.055) / 1.055) ** 2.4
    })
    const luminance = 0.2126 * r + 0.7152 * g + 0.0722 * b

    return luminance < 0.5 ? 'dark' : 'light'
  }

  const setUiTone = () => {
    root.setAttribute('data-ui-tone', resolveThemeTone())
  }

  setUiTone()

  new MutationObserver((changes) => {
    if (changes.some((change) => change.attributeName === 'data-theme')) {
      setUiTone()
    }
  }).observe(root, { attributes: true, attributeFilter: ['data-theme'] })
</script>

<style>
  .project-intro {
    background: linear-gradient(
      160deg,
      color-mix(in srgb, var(--theme-accent), transparent 95%),
      color-mix(in srgb, var(--theme-background), var(--theme-accent) 4%)
    );
  }

  .meta-chip {
    display: inline-flex;
    align-items: center;
    font-size: 0.8rem;
    padding: 0.3rem 0.55rem;
    border-radius: 0.55rem;
    border: 1px solid color-mix(in srgb, var(--theme-foreground), transparent 80%);
    background: color-mix(in srgb, var(--theme-accent), transparent 92%);
  }

  /* === Project row: image + info panel === */
  .project-row {
    --tone: var(--card-tone, var(--theme-accent));
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .project-row {
      grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
      gap: 2.5rem;
    }

    .project-row--reversed {
      grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
    }

    .project-row--reversed .image-card {
      grid-column: 2;
      grid-row: 1;
    }

    .project-row--reversed .info-panel {
      grid-column: 1;
      grid-row: 1;
      text-align: right;
    }

    .project-row--reversed .info-top {
      flex-direction: row-reverse;
    }

    .project-row--reversed .info-actions {
      justify-content: flex-end;
    }
  }

  /* === Image card === */
  .image-card {
    position: relative;
    display: block;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    border-radius: 1rem;
    border: 1px solid color-mix(in srgb, var(--tone), transparent 60%);
    background: color-mix(in srgb, var(--theme-background), var(--tone) 8%);
    text-decoration: none;
    color: inherit;
    isolation: isolate;
    box-shadow: 0 6px 20px color-mix(in srgb, var(--tone), transparent 90%);
    transition:
      transform 0.35s cubic-bezier(0.2, 0.7, 0.2, 1),
      box-shadow 0.35s ease,
      border-color 0.35s ease;
  }

  .image-card:hover {
    transform: scale(1.015);
    border-color: color-mix(in srgb, var(--tone), transparent 35%);
    box-shadow: 0 18px 40px color-mix(in srgb, var(--tone), transparent 78%);
  }

  .image-card:focus {
    outline: none;
  }

  .image-card:focus-visible {
    outline: 2px solid var(--tone);
    outline-offset: 3px;
  }

  .thumb-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: left top;
    transition: opacity 0.28s ease;
    opacity: 0;
  }

  .thumb-image-light {
    opacity: 1;
  }

  .thumb-image-dark {
    opacity: 0;
  }

  :root[data-ui-tone='dark'] .thumb-image-light {
    opacity: 0;
  }

  :root[data-ui-tone='dark'] .thumb-image-dark {
    opacity: 1;
  }

  /* === Info panel: minimal content beside the image === */
  .info-panel {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .info-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-bottom: 0.15rem;
  }

  .repo-path {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, monospace;
    font-size: 0.72rem;
    opacity: 0.6;
    letter-spacing: 0.01em;
    word-break: break-all;
    min-width: 0;
  }

  .repo-icon {
    flex-shrink: 0;
    opacity: 0.7;
  }

  .live-status {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--tone), transparent 65%);
    background: color-mix(in srgb, var(--tone), transparent 90%);
    color: color-mix(in srgb, var(--tone), var(--theme-foreground) 55%);
    flex-shrink: 0;
  }

  .live-dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    background: var(--tone);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--tone), transparent 50%);
    animation: pulse 1.8s ease-in-out infinite;
  }

  .info-tagline {
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 700;
    color: color-mix(in srgb, var(--tone), var(--theme-foreground) 40%);
    opacity: 0.95;
  }

  .info-title {
    font-size: 1.5rem;
    line-height: 1.15;
    font-weight: 700;
    color: var(--theme-foreground);
  }

  @media (min-width: 768px) {
    .info-title {
      font-size: 1.75rem;
    }
  }

  @media (min-width: 1024px) {
    .info-title {
      font-size: 2rem;
    }
  }

  .info-description {
    font-size: 0.92rem;
    line-height: 1.55;
    opacity: 0.78;
    margin-top: 0.1rem;
  }

  /* === CTAs === */
  .info-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.6rem;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    padding: 0.55rem 0.95rem;
    border-radius: 0.6rem;
    border: 1px solid transparent;
    color: inherit;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease,
      box-shadow 0.2s ease,
      color 0.2s ease,
      filter 0.2s ease;
  }

  .cta:focus-visible {
    outline: 2px solid var(--tone);
    outline-offset: 2px;
  }

  .cta-primary {
    background: var(--tone);
    border-color: var(--tone);
    color: #0b0d10;
  }

  :root[data-ui-tone='light'] .cta-primary {
    color: #fff;
  }

  .cta-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 20px color-mix(in srgb, var(--tone), transparent 65%);
    filter: brightness(1.08);
  }

  .cta-secondary {
    background: transparent;
    border-color: color-mix(in srgb, var(--theme-foreground), transparent 75%);
  }

  .cta-secondary:hover {
    transform: translateY(-1px);
    background: color-mix(in srgb, var(--tone), transparent 92%);
    border-color: color-mix(in srgb, var(--tone), transparent 45%);
    color: color-mix(in srgb, var(--tone), var(--theme-foreground) 50%);
  }

  .cta-icon {
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--tone), transparent 50%);
    }
    50% {
      box-shadow: 0 0 0 4px color-mix(in srgb, var(--tone), transparent 100%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .image-card,
    .cta,
    .live-dot {
      transition: none;
      animation: none;
    }

    .image-card:hover {
      transform: none;
    }
  }
</style>
