---
import Layout from '~/layouts/Layout.astro'
import PageHeader from '~/components/PageHeader.astro'

const projects = [
  {
    name: 'Resource Translator',
    description:
      'A GitHub Action that translates .resx and localization resources for .NET apps and repositories.',
    repoUrl: 'https://github.com/IEvangelist/resource-translator',
    pagesUrl: 'https://ievangelist.github.io/resource-translator/',
    lightThumbnail: '/images/projects/resource-translator-light.png',
    darkThumbnail: '/images/projects/resource-translator-dark.png',
    accent: 'from-cyan-500/65 via-blue-500/55 to-violet-500/65',
    repoPath: 'IEvangelist/resource-translator',
    tags: ['GitHub Actions', '.NET', 'Localization'],
  },
  {
    name: 'Profanity Filter',
    description:
      'A modern .NET profanity filtering solution with docs published to GitHub Pages.',
    repoUrl: 'https://github.com/IEvangelist/profanity-filter',
    pagesUrl: 'https://ievangelist.github.io/profanity-filter/',
    lightThumbnail: '/images/projects/profanity-filter-light.png',
    darkThumbnail: '/images/projects/profanity-filter-dark.png',
    accent: 'from-pink-500/65 via-fuchsia-500/55 to-orange-500/65',
    repoPath: 'IEvangelist/profanity-filter',
    tags: ['GitHub Actions', '.NET', 'Moderation'],
  },
  {
    name: 'Netlify Aspire Integration',
    description:
      'A hosting integration that helps deploy Aspire-powered static experiences using Netlify.',
    repoUrl: 'https://github.com/IEvangelist/netlify-aspire-integration',
    pagesUrl: 'https://ievangelist.github.io/netlify-aspire-integration/',
    lightThumbnail: '/images/projects/netlify-aspire-integration-light.png',
    darkThumbnail: '/images/projects/netlify-aspire-integration-dark.png',
    accent: 'from-emerald-500/65 via-teal-500/55 to-sky-500/65',
    repoPath: 'IEvangelist/netlify-aspire-integration',
    tags: ['Aspire', 'Netlify', 'Cloud'],
  },
]
---

<Layout title="Projects" description="Featured projects by David Pine">
  <PageHeader title="Projects" />

  <article class="max-w-full py-7.5 space-y-7">
    <section class="project-intro rounded-xl border border-accent/20 p-5 md:p-6">
      <p class="m-0 text-lg md:text-xl">
        Built in public, shipped in production — quick access to each project’s live docs
        and source.
      </p>
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="meta-chip">{projects.length} Featured Repositories</span>
        <span class="meta-chip">Dual-theme previews</span>
        <span class="meta-chip">Live + source quick actions</span>
      </div>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
      {
        projects.map((project) => (
          <article
            class="project-card group rounded-xl overflow-hidden border border-accent/20 bg-accent/4"
          >
            <div class={`h-1.5 bg-gradient-to-r ${project.accent}`} />
            <div class="p-4 flex h-full flex-col">
              <div class="thumb-wrap mb-4">
                <div class={`thumb-glow bg-gradient-to-r ${project.accent}`} />
                <img
                  src={project.lightThumbnail}
                  alt={`${project.name} GitHub Pages deployment screenshot in light mode`}
                  class="thumb-image thumb-image-light"
                  loading="lazy"
                />
                <img
                  src={project.darkThumbnail}
                  alt={`${project.name} GitHub Pages deployment screenshot in dark mode`}
                  class="thumb-image thumb-image-dark"
                  loading="lazy"
                />
                <span class="thumb-badge">GitHub Pages</span>
              </div>

              <div class="space-y-2 mb-3">
                <p class="repo-path m-0">{project.repoPath}</p>
                <h2 class="text-xl m-0 text-accent">{project.name}</h2>
                <p class="m-0 opacity-85">{project.description}</p>
              </div>

              <div class="flex flex-wrap gap-2 mb-4">
                {project.tags.map((tag) => (
                  <span class="inline-flex text-xs px-2 py-1 rounded-md border border-foreground/20">
                    {tag}
                  </span>
                ))}
              </div>

              <div class="mt-auto flex items-center justify-between text-sm">
                <span class="inline-flex items-center gap-1.5 opacity-75"><span class="live-dot" />Live</span>
                <span class="opacity-70">github.com</span>
              </div>

              <div class="mt-3 grid grid-cols-2 gap-2">
                <a
                  href={project.pagesUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="project-cta"
                >
                  Open live site ↗
                </a>
                <a
                  href={project.repoUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="project-cta"
                >
                  Open repository ↗
                </a>
              </div>

              <p class="m-0 mt-2 text-xs opacity-65 truncate">{project.pagesUrl}</p>
            </div>
          </article>
        ))
      }
    </div>
  </article>
</Layout>

<script>
  const root = document.documentElement
  const setUiTone = () => {
    const activeTheme = root.getAttribute('data-theme')
    const darkTheme = root.getAttribute('data-dark-theme')
    const lightTheme = root.getAttribute('data-light-theme')
    let uiTone = 'light'

    if (activeTheme === darkTheme) {
      uiTone = 'dark'
    } else if (activeTheme === lightTheme) {
      uiTone = 'light'
    } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
      uiTone = 'dark'
    }

    root.setAttribute('data-ui-tone', uiTone)
  }

  setUiTone()

  new MutationObserver((changes) => {
    if (changes.some((change) => change.attributeName === 'data-theme')) {
      setUiTone()
    }
  }).observe(root, { attributes: true, attributeFilter: ['data-theme'] })
</script>

<style>
  .project-card {
    position: relative;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .project-card:hover {
    transform: translateY(-6px);
    border-color: color-mix(in srgb, var(--theme-accent), transparent 38%);
    box-shadow: 0 16px 36px color-mix(in srgb, var(--theme-accent), transparent 80%);
  }

  .project-intro {
    background: linear-gradient(
      160deg,
      color-mix(in srgb, var(--theme-accent), transparent 95%),
      color-mix(in srgb, var(--theme-background), var(--theme-accent) 4%)
    );
  }

  .meta-chip {
    display: inline-flex;
    align-items: center;
    font-size: 0.8rem;
    padding: 0.3rem 0.55rem;
    border-radius: 0.55rem;
    border: 1px solid color-mix(in srgb, var(--theme-foreground), transparent 80%);
    background: color-mix(in srgb, var(--theme-accent), transparent 92%);
  }

  .thumb-wrap {
    position: relative;
    height: 190px;
    border-radius: 0.6rem;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--theme-foreground), transparent 82%);
    background: color-mix(in srgb, var(--theme-background), var(--theme-accent) 8%);
    isolation: isolate;
  }

  .thumb-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 190px;
    display: block;
    object-fit: cover;
    transition: opacity 0.28s ease;
    opacity: 0;
    z-index: 1;
  }

  .thumb-image-light {
    opacity: 1;
  }

  .thumb-image-dark {
    opacity: 0;
  }

  :root[data-ui-tone='dark'] .thumb-image-light {
    opacity: 0;
  }

  :root[data-ui-tone='dark'] .thumb-image-dark {
    opacity: 1;
  }

  .repo-path {
    font-size: 0.8rem;
    opacity: 0.65;
  }

  .thumb-badge {
    position: absolute;
    top: 0.55rem;
    left: 0.55rem;
    font-size: 0.68rem;
    letter-spacing: 0.01em;
    padding: 0.18rem 0.45rem;
    border-radius: 0.45rem;
    border: 1px solid color-mix(in srgb, var(--theme-accent), transparent 35%);
    background: color-mix(in srgb, var(--theme-background), var(--theme-accent) 18%);
    backdrop-filter: blur(3px);
    z-index: 2;
  }

  .thumb-glow {
    position: absolute;
    inset: 0;
    opacity: 0.14;
    pointer-events: none;
    mix-blend-mode: screen;
    z-index: 1;
  }

  .live-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--theme-accent), var(--theme-green) 35%);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--theme-accent), transparent 58%);
    animation: pulse 1.8s ease-in-out infinite;
  }

  .project-cta {
    font-size: 0.74rem;
    text-align: center;
    text-decoration: none;
    padding: 0.4rem 0.55rem;
    border-radius: 0.5rem;
    border: 1px solid color-mix(in srgb, var(--theme-foreground), transparent 75%);
    background: color-mix(in srgb, var(--theme-accent), transparent 94%);
    color: inherit;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .project-cta:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--theme-accent), transparent 48%);
    background: color-mix(in srgb, var(--theme-accent), transparent 89%);
  }

  @keyframes pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--theme-accent), transparent 58%);
    }
    50% {
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--theme-accent), transparent 100%);
    }
  }
</style>
