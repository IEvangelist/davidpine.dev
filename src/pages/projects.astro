---
import Layout from '~/layouts/Layout.astro'
import PageHeader from '~/components/PageHeader.astro'

const projects = [
  {
    name: 'Resource Translator',
    description:
      'A GitHub Action that translates .resx and localization resources for .NET apps and repositories.',
    repoUrl: 'https://github.com/IEvangelist/resource-translator',
    thumbnail: '/images/projects/resource-translator.png',
    accent: 'from-cyan-500/55 via-blue-500/45 to-violet-500/55',
    repoPath: 'IEvangelist/resource-translator',
    tags: ['GitHub Actions', '.NET', 'Localization'],
  },
  {
    name: 'GitHub Profanity Filter',
    description:
      'An Azure Functions-powered filter that scans GitHub issues and PRs to detect and clean profane language.',
    repoUrl: 'https://github.com/IEvangelist/GitHub.ProfanityFilter',
    thumbnail: '/images/projects/github-profanity-filter.png',
    accent: 'from-pink-500/55 via-fuchsia-500/45 to-orange-500/55',
    repoPath: 'IEvangelist/GitHub.ProfanityFilter',
    tags: ['Azure Functions', 'GitHub Webhooks', 'C#'],
  },
  {
    name: 'Netlify Aspire Integration',
    description:
      'A hosting integration that helps deploy Aspire-powered static experiences using Netlify.',
    repoUrl: 'https://github.com/IEvangelist/netlify-aspire-integration',
    thumbnail: '/images/projects/netlify-aspire-integration.png',
    accent: 'from-emerald-500/55 via-teal-500/45 to-sky-500/55',
    repoPath: 'IEvangelist/netlify-aspire-integration',
    tags: ['Aspire', 'Netlify', 'Cloud'],
  },
]
---

<Layout title="Projects" description="Featured projects by David Pine">
  <PageHeader title="Projects" />

  <article class="max-w-full py-7.5 space-y-7">
    <section class="project-intro rounded-xl border border-accent/20 p-5 md:p-6">
      <p class="m-0 text-lg md:text-xl">
        Built in public, shipped in the real world — these are featured repositories with
        direct links and live GitHub page previews.
      </p>
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="meta-chip">{projects.length} Featured Repositories</span>
        <span class="meta-chip">GitHub-first OSS</span>
        <span class="meta-chip">Open source + cloud</span>
      </div>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
      {
        projects.map((project) => (
          <a
            href={project.repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="project-card group block no-underline rounded-xl overflow-hidden border border-accent/20 bg-accent/4"
          >
            <div class={`h-1.5 bg-gradient-to-r ${project.accent}`} />
            <div class="p-4 flex h-full flex-col">
              <div class="thumb-wrap mb-4">
                <img
                  src={project.thumbnail}
                  alt={`${project.name} GitHub page screenshot`}
                  class="thumb-image"
                  loading="lazy"
                />
              </div>

              <div class="space-y-2 mb-3">
                <p class="repo-path m-0">{project.repoPath}</p>
                <h2 class="text-xl m-0 text-accent">{project.name}</h2>
                <p class="m-0 opacity-85">{project.description}</p>
              </div>

              <div class="flex flex-wrap gap-2 mb-4">
                {project.tags.map((tag) => (
                  <span class="inline-flex text-xs px-2 py-1 rounded-md border border-foreground/20">
                    {tag}
                  </span>
                ))}
              </div>

              <div class="mt-auto flex items-center justify-between text-sm">
                <span class="opacity-75">github.com</span>
                <span class="inline-flex text-accent group-hover:translate-x-0.5 transition-transform">
                  Open repository →
                </span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </article>
</Layout>

<style>
  .project-card {
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--theme-accent), transparent 45%);
    box-shadow: 0 10px 26px color-mix(in srgb, var(--theme-accent), transparent 82%);
  }

  .project-intro {
    background: linear-gradient(
      160deg,
      color-mix(in srgb, var(--theme-accent), transparent 95%),
      color-mix(in srgb, var(--theme-background), var(--theme-accent) 4%)
    );
  }

  .meta-chip {
    display: inline-flex;
    align-items: center;
    font-size: 0.8rem;
    padding: 0.3rem 0.55rem;
    border-radius: 0.55rem;
    border: 1px solid color-mix(in srgb, var(--theme-foreground), transparent 80%);
    background: color-mix(in srgb, var(--theme-accent), transparent 92%);
  }

  .thumb-wrap {
    border-radius: 0.6rem;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--theme-foreground), transparent 82%);
    background: color-mix(in srgb, var(--theme-background), var(--theme-accent) 6%);
  }

  .thumb-image {
    width: 100%;
    height: 190px;
    display: block;
    object-fit: cover;
  }

  .repo-path {
    font-size: 0.8rem;
    opacity: 0.65;
  }
</style>
